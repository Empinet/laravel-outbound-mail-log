{
    "name": "empinet/laravel-outbound-mail-log",
    "description": "Log outbound emails sent by Laravel into a database table.",
    "keywords": [
        "empinet",
        "laravel",
        "mail",
        "email",
        "log"
    ],
    "homepage": "https://github.com/empinet/laravel-outbound-mail-log",
    "license": "MIT",
    "authors": [
        {
            "name": "Empinet",
            "role": "Maintainer"
        }
    ],
    "require": {
        "php": "^8.2",
        "illuminate/console": "^10.0 || ^11.0 || ^12.0",
        "illuminate/database": "^10.0 || ^11.0 || ^12.0",
        "illuminate/events": "^10.0 || ^11.0 || ^12.0",
        "illuminate/mail": "^10.0 || ^11.0 || ^12.0",
        "illuminate/support": "^10.0 || ^11.0 || ^12.0"
    },
    "require-dev": {
        "laravel/pint": "^1.18",
        "orchestra/testbench": "^8.0 || ^9.0 || ^10.0",
        "pestphp/pest": "^3.0",
        "pestphp/pest-plugin-arch": "^3.0",
        "pestphp/pest-plugin-laravel": "^3.0"
    },
    "autoload": {
        "psr-4": {
            "Empinet\\OutboundMailLog\\": "src/",
            "Empinet\\OutboundMailLog\\Database\\Factories\\": "database/factories/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Empinet\\OutboundMailLog\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Empinet\\OutboundMailLog\\OutboundMailLogServiceProvider"
            ]
        }
    },
    "scripts": {
        "test": "vendor/bin/pest",
        "format": "vendor/bin/pint",
        "format:check": "vendor/bin/pint --test"
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
